---
import Layout from '../layouts/Layout.astro';
import ExperienceCenter from '../components/ExperienceCenter.jsx';
---

<Layout title="Experience Center · MyRecruiter" description="A self-guided demo of MyRecruiter — walk a supporter from first question to completed action across volunteer, donor, program, and event journeys.">
    <ExperienceCenter client:only="preact" />
</Layout>

<style is:global>
    /* This route is a standalone immersive shell — no marketing nav/footer. */
    body { margin: 0; background: #0F172A; }

    /* Keyframes (from the prototype's <style> block) */
    @keyframes ecFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
    @keyframes ecPop { from { opacity: 0; transform: scale(.94); } to { opacity: 1; transform: scale(1); } }
    @keyframes ecPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(80,200,120,.45); } 50% { box-shadow: 0 0 0 7px rgba(80,200,120,0); } }
    @keyframes ecPulseG { 0%, 100% { box-shadow: 0 0 0 0 rgba(161,144,95,.45); } 50% { box-shadow: 0 0 0 7px rgba(161,144,95,0); } }
    @keyframes ecDot { 0%, 60%, 100% { transform: translateY(0); opacity: .35; } 30% { transform: translateY(-3px); opacity: 1; } }
    @keyframes ecFlow { to { stroke-dashoffset: -22; } }
    @keyframes ecNudge { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(5px); } }
    @keyframes ecLive { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }
    ::selection { background: rgba(80,200,120,.25); }

    /* Sidebar logo / escape-hatch link (from the prototype) */
    .ec-logo-link { position: relative; display: block; }
    .ec-logo-hint { opacity: 0; transform: translateY(-2px); transition: opacity .18s cubic-bezier(.4,0,.2,1), transform .18s cubic-bezier(.4,0,.2,1); font-size: 10.5px; font-weight: 600; letter-spacing: .02em; color: #94A3B8; margin-top: 6px; display: block; }
    .ec-logo-link:hover .ec-logo-hint { opacity: 1; transform: none; }
    .ec-site-link { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: #94A3B8; cursor: pointer; transition: color .15s cubic-bezier(.4,0,.2,1); text-decoration: none; }
    .ec-site-link:hover { color: #fff; }

    /* Hover helpers replacing the DC `style-hover` attribute.
       ec-hoverbg reads a per-element --hb custom property. */
    .ec-hoverbg:hover { background: var(--hb) !important; }
    .ec-card:hover { box-shadow: 0 12px 32px rgba(15,23,42,.10) !important; transform: translateY(-2px) !important; }
    .ec-lift:hover { transform: translateY(-2px) !important; }
    .ec-heat:hover { transform: scale(1.08) !important; }
    .ec-hovercream:hover { background: #fbf8ee !important; }
    .ec-hovergold:hover { background: #8a7439 !important; }
    .ec-hoverborder:hover { border-color: #50C878 !important; }
    .ec-faq:hover { background: #fbf8ee !important; color: #0f172a !important; }
    .ec-btn-primary:hover { background: #5FD089 !important; }
    .ec-btn-outline:hover { background: #F8FAFC !important; }
    .ec-btn-outline-dark:hover { background: rgba(255,255,255,.05) !important; }

    /* ── Mobile / narrow tablet ──────────────────────────────────────────
       The island styles inline (no media queries), so these override with
       !important. Desktop (>860px) is untouched. */
    @media (max-width: 860px) {
        /* Shell: 238px sidebar + content doesn't fit — stack it, sidebar
           becomes a sticky top bar with a horizontally scrollable nav. */
        .ec-shell { flex-direction: column !important; }
        .ec-sidebar {
            width: 100% !important; height: auto !important;
            position: sticky !important; top: 0 !important; z-index: 30 !important;
        }
        .ec-sb-logo { padding: 12px 16px 6px !important; }
        .ec-logo-hint { display: none !important; }
        /* Secondary chrome would push content far down on a phone. */
        .ec-sb-eyebrow, .ec-sb-back, .ec-sb-cta { display: none !important; }
        .ec-navlist {
            flex-direction: row !important; overflow-x: auto !important;
            padding: 0 12px 10px !important; gap: 6px !important;
            scrollbar-width: none;
        }
        .ec-navlist::-webkit-scrollbar { display: none; }
        .ec-navlist > div { flex: 0 0 auto !important; white-space: nowrap !important; }

        /* Page padding: 44–48px side padding is unusable at 375px. */
        .ec-page { padding: 22px 18px 56px !important; }
        .ec-journey-card { padding: 18px 16px !important; }

        /* Fixed-min grids overflow below ~360px of content width. */
        .ec-grid, .ec-discover-grid { grid-template-columns: minmax(0, 1fr) !important; }
        .ec-kpis, .ec-chan-grid { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }

        /* Widget: 380px fixed + flex-shrink:0 forces overflow. */
        .ec-widget { width: 100% !important; height: 520px !important; }

        /* Stage rail: 5–6 stages can't compress — let it scroll. The connectors collapse to 0
           width here, so spacing would come from each label's width (38–78px) and the last stage
           — with the widest label — drifted away from the rest. Fixed-width items instead, so the
           circles are evenly spaced regardless of label length. */
        .ec-rail { overflow-x: auto !important; scrollbar-width: none; }
        .ec-rail::-webkit-scrollbar { display: none; }
        /* Equal share of the width (grow, never shrink below 58px): evenly spaced circles that
           still all fit on screen, falling back to a scroll only on the narrowest phones. */
        .ec-rail-item { flex: 1 0 58px !important; justify-content: center !important; }
        .ec-rail-line { display: none !important; }
        /* Label max-width is 78px inline; let it use the item's share instead of overflowing. */
        .ec-rail-item > div > div:last-child { max-width: 100% !important; }

        /* Bottom controls: Back + "Stage 6 of 6" + the next button over-run the row (420 needed
           vs 392 available), squeezing the counter until it wrapped mid-number. Trim the button
           padding, pin the counter, and let the row wrap on the narrowest phones. */
        .ec-stage-controls { flex-wrap: wrap !important; gap: 12px !important; }
        .ec-stage-count { white-space: nowrap !important; }
        .ec-stage-controls .ec-btn-primary,
        .ec-stage-controls .ec-btn-outline { padding-left: 14px !important; padding-right: 14px !important; }

        /* Home card previews: the bubbles are absolutely positioned at tops tuned for the wider
           desktop card, where they're ~40px tall. On a phone the copy wraps to 3 lines (55px) and
           the second bubble collided with the first (Donor overlapped by 6px, Event's chip by 1).
           Bubble height is capped by max-width, so it's a constant 55px across phone widths —
           these tops clear it with room to spare and still fit the 148px preview. */
        .ec-prev-q { top: 18px !important; }
        .ec-prev-a { top: 84px !important; }
        .ec-prev-chip { top: 106px !important; }
        /* 148px can't hold the taller wrapped content once it's spaced apart — at 320 the Event
           chip wraps to two lines and was clipped by the preview's overflow:hidden. */
        .ec-card-preview { height: 168px !important; }

        .ec-sector-row { flex-direction: column !important; }
        /* 32px of overlay padding wastes scarce width on a phone. */
        .ec-welcome-overlay { padding: 16px !important; }

        /* "Viewing as" row is 337px and won't wrap — overflows at 320px. */
        .ec-persp { flex-wrap: wrap !important; }
        .ec-persp-pills { max-width: 100% !important; overflow-x: auto !important; scrollbar-width: none; }
        .ec-persp-pills::-webkit-scrollbar { display: none; }

        /* Landing */
        .ec-landing-header { padding: 16px 18px !important; flex-wrap: wrap !important; gap: 10px !important; justify-content: center !important; }
        .ec-landing-pill { font-size: 11px !important; padding: 6px 12px !important; }
        .ec-landing-main { padding: 12px 18px 28px !important; }
        .ec-landing-h1 { font-size: 38px !important; }
        /* Final */
        .ec-final { padding: 40px 20px !important; }
        .ec-final-h1 { font-size: 30px !important; }
    }
</style>
