---
import HeroDemoScene from './HeroDemoScene.jsx';
---

<!-- Dark hero. Header is the existing fixed site nav (in index.astro). -->
<section class="relative overflow-hidden bg-[#0F172A]">
    <!-- Glow layers (behind everything) — exact tuned values from the prototype -->
    <div class="pointer-events-none absolute -top-[240px] -right-[140px] h-[900px] w-[900px] rounded-full"
         style="background:radial-gradient(circle,rgba(80,200,120,.28) 0%,rgba(80,200,120,0) 65%)"></div>
    <div class="pointer-events-none absolute -bottom-[300px] -left-[220px] h-[760px] w-[760px] rounded-full"
         style="background:radial-gradient(circle,rgba(80,200,120,.16) 0%,rgba(80,200,120,0) 65%)"></div>

    <main class="relative mx-auto grid max-w-6xl items-center gap-12 px-6 pb-6 pt-28 lg:grid-cols-[minmax(0,1.05fr)_470px] lg:gap-[60px] lg:pb-6 lg:pt-[124px]">
        <!-- Left column -->
        <div>
            <!-- Icon + one text block (not three flex items): when the copy wraps on a phone,
                 the second line aligns under "Nights…" rather than under the icon. -->
            <div class="inline-flex items-start gap-[9px] rounded-3xl border border-white/[.14] bg-white/[.07] px-[17px] py-[9px] text-[13.5px] font-semibold text-white/[.85] backdrop-blur-lg sm:rounded-full">
                <span class="flex-none text-[13px] leading-[1.5]">🌙</span>
                <span class="leading-[1.5]">Nights and weekends, your team is offline. <span class="text-emerald-300">MyRecruiter isn't.</span></span>
            </div>

            <h1 class="mt-[22px] text-[40px] font-bold leading-[1.06] tracking-[-0.02em] text-white [text-wrap:pretty] sm:text-[57px]">
                Never miss another volunteer or donor inquiry again.
            </h1>

            <p class="mt-[18px] max-w-[580px] text-[17px] leading-[1.62] text-white/[.72]">
                When someone decides to help, every hour matters. MyRecruiter removes the friction between people and your mission—so more people become volunteers, donors, and advocates while your team stays focused on changing lives.
            </p>

            <!-- Chip flow — two balanced rows so it never wraps to a lone stray chip -->
            <div class="mt-6 flex flex-col gap-[9px]">
                <div class="flex flex-wrap items-center gap-[7px]">
                    <span class="rounded-full border border-[rgba(80,200,120,.35)] bg-[rgba(80,200,120,.13)] px-[14px] py-2 text-[12.5px] font-semibold text-emerald-300">Answers questions</span>
                    <span class="text-[12px] text-white/[.35]">→</span>
                    <span class="rounded-full border border-[rgba(80,200,120,.35)] bg-[rgba(80,200,120,.13)] px-[14px] py-2 text-[12.5px] font-semibold text-emerald-300">Guides supporters</span>
                </div>
                <div class="flex flex-wrap items-center gap-[7px]">
                    <span class="rounded-full border border-[rgba(80,200,120,.35)] bg-[rgba(80,200,120,.13)] px-[14px] py-2 text-[12.5px] font-semibold text-emerald-300">Books appointments</span>
                    <span class="text-[12px] text-white/[.35]">→</span>
                    <span class="rounded-full border border-[rgba(80,200,120,.35)] bg-[rgba(80,200,120,.13)] px-[14px] py-2 text-[12.5px] font-semibold text-emerald-300">Keeps everyone on track</span>
                </div>
            </div>

            <!-- CTAs -->
            <div class="mt-8 flex flex-col items-stretch gap-[14px] sm:flex-row sm:items-center">
                <a href="/experience"
                   class="inline-flex items-center justify-center gap-2 rounded-full bg-emerald-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-emerald-500/25 transition-all hover:bg-emerald-400">
                    Try the Interactive Demo
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="/demo"
                   class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 px-7 py-3.5 text-base font-medium text-white transition-all hover:bg-white/5">
                    Book a Live Demo
                </a>
            </div>

            <div class="mt-4 text-[13px] text-white/50">Works alongside your team • Live in days • We handle the setup</div>
        </div>

        <!-- Right column — channel icons + animation -->
        <div>
            <div class="mb-3 flex flex-wrap items-center justify-center gap-2 text-[12.5px] font-semibold">
                <span title="Website" class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-full border border-white/[.28] bg-white/[.12]">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg>
                </span>
                <span title="Facebook" class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-full border border-white/[.28] bg-white/[.12]">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                </span>
                <span title="Instagram" class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-full border border-white/[.28] bg-white/[.12]">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </span>
                <span title="Print & QR" class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-full border border-white/[.28] bg-white/[.12]">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"></path><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
                </span>
                <span class="ml-1.5 text-emerald-300">— one assistant, everywhere you market</span>
            </div>
            <!-- Animation container: NO background of its own — the section glow shows through.
                 w-full + max-w keeps it from forcing the single-column grid wider than the
                 viewport on mobile; the 470/648 aspect preserves the desktop framing as it scales. -->
            <div class="relative mx-auto aspect-[470/648] w-full max-w-[470px] overflow-hidden rounded-2xl">
                <HeroDemoScene client:load speed={0.75} showTimeChip={true} />
            </div>
        </div>
    </main>

    <!-- Proof strip — no divider and no opaque fill: a transparent-topped gradient lets the
         hero's navy + emerald glow carry through behind the stats, then resolves to the white of
         the section below (LogoTicker is bg-white) so the seam is invisible. Navy holds to 62%
         and white lands by 92%, compressing the fade so it doesn't linger in blue-gray. -->
    <div class="relative mt-3 pb-[140px] pt-2" style="background:linear-gradient(to bottom,transparent 0%,transparent 62%,#FFFFFF 92%)">
        <!-- Alignment by width: stacked on a phone the rows left-align and the number sits in a
             fixed column, so numbers and labels each line up. Once the four fit on one line
             (~1130px) justify-between puts the first/last on the nav/headline content edges. -->
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-start gap-x-14 gap-y-4 px-6 sm:justify-center min-[1130px]:justify-between">
            <div class="flex items-baseline gap-[9px]"><span class="min-w-[56px] text-[23px] font-bold text-emerald-300 sm:min-w-0">65%</span><span class="text-[12.5px] text-white/[.55]">Conversations become action</span></div>
            <div class="flex items-baseline gap-[9px]"><span class="min-w-[56px] text-[23px] font-bold text-emerald-300 sm:min-w-0">8×</span><span class="text-[12.5px] text-white/[.55]">More volunteer applications</span></div>
            <div class="flex items-baseline gap-[9px]"><span class="min-w-[56px] text-[23px] font-bold text-emerald-300 sm:min-w-0">49%</span><span class="text-[12.5px] text-white/[.55]">Engagement happens after hours</span></div>
            <div class="flex items-baseline gap-[9px]"><span class="min-w-[56px] text-[23px] font-bold text-emerald-300 sm:min-w-0">24/7</span><span class="text-[12.5px] text-white/[.55]">Your mission never closes</span></div>
        </div>
    </div>
</section>
